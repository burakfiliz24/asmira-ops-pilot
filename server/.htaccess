RewriteEngine On

# Dizin listelemeyi kapat
Options -Indexes

# Güvenlik başlıkları
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Hassas dosyalara erişimi engelle
<FilesMatch "(db_config|config|middleware|helpers|\.env|\.log|\.sql|\.ini|\.bak|\.backup)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# .git dizinine erişimi engelle
RewriteRule ^\.git - [F,L]

# includes/ dizinine erişimi engelle
RewriteRule ^includes/ - [F,L]

# pages/ dizinine doğrudan erişimi engelle
RewriteRule ^pages/ - [F,L]

# data/ dizinine erişimi engelle
RewriteRule ^data/ - [F,L]

# logs/ dizinine erişimi engelle
RewriteRule ^logs/ - [F,L]

# Gzip sıkıştırma
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Tarayıcı önbelleği
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# API istekleri - PHP dosyası varsa doğrudan serve et, yoksa index.php'ye yönlendir
RewriteCond %{REQUEST_URI} ^/api/
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]
RewriteCond %{REQUEST_URI} ^/api/
RewriteRule ^ index.php [L]

# Statik dosyalar (assets, images vs.) doğrudan serve et
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Tüm diğer istekleri front controller'a yönlendir
RewriteRule ^ index.php [L]

# Custom Error Documents
ErrorDocument 404 /index.php
ErrorDocument 403 /index.php
