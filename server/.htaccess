RewriteEngine On

# Güvenlik başlıkları
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Hassas dosyalara erişimi engelle
<FilesMatch "(db_config|config|\.env|\.log|\.sql|\.ini)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# includes/ dizinine erişimi engelle
RewriteRule ^includes/ - [F,L]

# pages/ dizinine doğrudan erişimi engelle
RewriteRule ^pages/ - [F,L]

# data/ dizinine erişimi engelle
RewriteRule ^data/ - [F,L]

# logs/ dizinine erişimi engelle
RewriteRule ^logs/ - [F,L]

# Gzip sıkıştırma
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Tarayıcı önbelleği
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# API istekleri - mevcut .htaccess'e yönlendir
RewriteRule ^api/ - [L]

# Statik dosyalar (assets, images vs.) doğrudan serve et
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Tüm diğer istekleri front controller'a yönlendir
RewriteRule ^ index.php [L]

# Custom Error Documents
ErrorDocument 404 /index.php
ErrorDocument 403 /index.php
