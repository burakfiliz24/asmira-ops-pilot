RewriteEngine On

# CORS preflight
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Auth login
RewriteRule ^auth/login/?$ auth/login.php [L,QSA]

# API endpoints (uzantısız erişim)
RewriteRule ^users/?$ users.php [L,QSA]
RewriteRule ^operations/?$ operations.php [L,QSA]
RewriteRule ^trucks/?$ trucks.php [L,QSA]
RewriteRule ^trailers/?$ trailers.php [L,QSA]
RewriteRule ^drivers/?$ drivers.php [L,QSA]
RewriteRule ^vehicle-sets/?$ vehicle-sets.php [L,QSA]
RewriteRule ^deliverers/?$ deliverers.php [L,QSA]
RewriteRule ^init-db/?$ init-db.php [L,QSA]

# Petitions
RewriteRule ^petition-categories/?$ petition-categories.php [L,QSA]
RewriteRule ^petition-templates/?$ petition-templates.php [L,QSA]
RewriteRule ^supplier-companies/?$ supplier-companies.php [L,QSA]

# Documents
RewriteRule ^documents/upload/?$ documents/upload.php [L,QSA]
RewriteRule ^documents/update/?$ documents/update.php [L,QSA]
RewriteRule ^documents/download/(.+)$ documents/download.php [L,QSA]

# Port Wiki
RewriteRule ^port-wiki/?$ port-wiki.php [L,QSA]
