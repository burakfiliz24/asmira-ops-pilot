# ===========================================
# VERİTABANI AYARLARI
# ===========================================

# Veritabanı tipi: "sqlite" veya "mariadb"
DB_TYPE=sqlite

# MariaDB/MySQL Ayarları (DB_TYPE=mariadb ise gerekli)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=asmira_ops

# ===========================================
# SUPABASE (Opsiyonel - Realtime için)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# UYGULAMA AYARLARI
# ===========================================
NEXT_PUBLIC_APP_URL=https://your-domain.com
